# Wandrix local environment template.
# Copy this file to `.env` for local development. Do not commit real secrets.

# Frontend public values. These are safe to expose in the browser.
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_API_BASE_URL=http://127.0.0.1:8000
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-supabase-publishable-key

# Backend app and CORS.
APP_ENV=development
FRONTEND_ORIGIN=http://localhost:3000
# Use FRONTEND_ORIGINS for testing/production when more than one frontend URL is allowed.
# FRONTEND_ORIGINS=http://localhost:3000,https://testing.example.com
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/wandrix

# Supabase backend values.
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_PUBLISHABLE_KEY=your-supabase-publishable-key
SUPABASE_SECRET_KEY=your-supabase-secret-or-service-role-key

# AI runtime.
CODEX_LB_BASE_URL=https://your-codex-lb-instance.com/v1
CODEX_LB_API_KEY=your-codex-lb-api-key
OPENAI_MODEL=gpt-5.4-mini
QUICK_PLAN_MODEL=gpt-5.5
QUICK_PLAN_REASONING_EFFORT=medium
QUICK_PLAN_STAGE_ONE_ONLY=true

# Optional LangSmith tracing.
LANGSMITH_TRACING=false
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=wandrix

# Flight provider.
AMADEUS_ENV=test
AMADEUS_CLIENT_ID=
AMADEUS_CLIENT_SECRET=

# Weather provider.
WEATHER_PROVIDER=open-meteo
OPEN_METEO_BASE_URL=https://api.open-meteo.com/v1

# Map and location providers.
MAP_PROVIDER=mapbox
MAPBOX_BASE_URL=https://api.mapbox.com
MAPBOX_ACCESS_TOKEN=
ACTIVITIES_PROVIDER=ai
POI_PROVIDER=geoapify
GEOAPIFY_BASE_URL=https://api.geoapify.com/v2
GEOAPIFY_API_KEY=

# Hotel providers.
HOTEL_PROVIDER=xotelo
RAPIDAPI_KEY=
RAPIDAPI_XOTELO_BASE_URL=https://xotelo-hotel-prices.p.rapidapi.com
RAPIDAPI_AGODA_BASE_URL=https://agoda-com.p.rapidapi.com
RAPIDAPI_HOTELS_COM_BASE_URL=https://hotels-com6.p.rapidapi.com
RAPIDAPI_TRAVEL_ADVISOR_BASE_URL=https://travel-advisor.p.rapidapi.com

# Events provider.
EVENTS_PROVIDER=ticketmaster
TICKETMASTER_BASE_URL=https://app.ticketmaster.com/discovery/v2
TICKETMASTER_CONSUMER_KEY=
TICKETMASTER_CONSUMER_SECRET=

# Travel content providers.
TRAVEL_CONTENT_PROVIDER=wikimedia
WIKIMEDIA_TRAVEL_BASE_URL=https://api.wikimedia.org/wiki/Travel
TRAVELPAYOUTS_BASE_URL=https://api.travelpayouts.com
TRAVELPAYOUTS_API_TOKEN=
